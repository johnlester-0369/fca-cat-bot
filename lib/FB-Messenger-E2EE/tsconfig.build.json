{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    // allowImportingTsExtensions requires noEmit:true — must disable it to emit declarations
    "allowImportingTsExtensions": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist"
  }
}