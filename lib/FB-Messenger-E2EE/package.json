  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.8.3"
  },
  "trustedDependencies": [
    "@signalapp/libsignal-client"
  ]
