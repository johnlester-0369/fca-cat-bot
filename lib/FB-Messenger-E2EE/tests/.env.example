###############################################
# Core runtime
###############################################

# Optional. Defaults shown here.
FB_APPSTATE_PATH=./tests/appstate.json
FB_SESSION_STORE_PATH=./tests/session.json
FB_PLATFORM=facebook


###############################################
# DGW integration inside FBClient.connectE2EE
# Used by src/controllers/client.controller.ts
###############################################

# Enable DGW bootstrap in connectE2EE
# 0 = off (default), 1 = on
FB_DGW_ENABLE=0

# Captured WebSocket endpoints from browser session
FB_DGW_URL_LIGHTSPEED=wss://gateway.facebook.com/ws/lightspeed?x-dgw-appid=2220391788200892&x-dgw-appversion=0&x-dgw-authtype=1:0&x-dgw-version=5&x-dgw-uuid=100050349247667&x-dgw-tier=prod&x-dgw-loggingid=REPLACE_ME&x-dgw-regionhint=HIL&x-dgw-deviceid=REPLACE_ME
FB_DGW_URL_STREAMCONTROLLER=wss://gateway.facebook.com/ws/streamcontroller?x-dgw-appid=2220391788200892&x-dgw-appversion=0&x-dgw-authtype=1:0&x-dgw-version=5&x-dgw-uuid=100050349247667&x-dgw-tier=prod&x-dgw-deviceid=REPLACE_ME&x-dgw-app-stream-group=group1
FB_DGW_URL_REALTIME=wss://gateway.facebook.com/ws/realtime?x-dgw-appid=2220391788200892&x-dgw-appversion=0&x-dgw-authtype=1:0&x-dgw-version=5&x-dgw-uuid=100050349247667&x-dgw-tier=prod&x-dgw-deviceid=REPLACE_ME&x-dgw-app-stream-group=group1

# Optional override headers
FB_DGW_UA=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36
FB_DGW_ORIGIN=https://www.facebook.com
FB_DGW_REFERER=https://www.facebook.com/
FB_DGW_ACCEPT_LANGUAGE=en-US,en;q=0.9

# Optional bootstrap OPEN frame tuning
FB_DGW_STREAM_ID=1
FB_DGW_BOOTSTRAP_METHOD=FBGQLS:XDT_DIRECT_REALTIME_EVENT
FB_DGW_BOOTSTRAP_DOC_ID=9712315318850438
FB_DGW_BOOTSTRAP_ROUTING_HINT=useIGDTypingIndicatorSubscription
FB_DGW_BOOTSTRAP_BODY=true
FB_DGW_BOOTSTRAP_ACCEPT_ACK=RSAck
FB_DGW_BOOTSTRAP_REFERER=https://www.facebook.com/messages/

# Optional DATA bootstrap frame (after OPEN)
# Option A: provide raw payload hex directly
FB_DGW_BOOTSTRAP_DATA_PAYLOAD_HEX=

# Option B: build payload as prefixHex + JSON + suffixHex
FB_DGW_BOOTSTRAP_DATA_JSON=
# Auto build default JSON payload when FB_DGW_BOOTSTRAP_DATA_JSON is empty.
# Default = 1 (enabled). Set 0 to disable auto payload.
FB_DGW_BOOTSTRAP_DATA_AUTO=1
FB_DGW_BOOTSTRAP_DATA_PREFIX_HEX=2c1878
FB_DGW_BOOTSTRAP_DATA_SUFFIX_HEX=0000
FB_DGW_BOOTSTRAP_DATA_TARGETS=realtime,streamcontroller
FB_DGW_BOOTSTRAP_DATA_REQUIRES_ACK=1
FB_DGW_BOOTSTRAP_DATA_ACK_ID=0


###############################################
# Standalone DGW probe script
# Used by tests/script/probe-dgw.ts
###############################################

# Full cookie header string from logged-in browser session
DGW_COOKIE=c_user=...; xs=...; fr=...; datr=...;

# Usually same as FB_DGW_UA / FB_DGW_ORIGIN
DGW_UA=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36
DGW_ORIGIN=https://www.facebook.com
DGW_TIMEOUT_MS=12000

# Reuse same endpoint values if desired
DGW_URL_LIGHTSPEED=
DGW_URL_STREAMCONTROLLER=
DGW_URL_REALTIME=

###############################################
# E2EE media upload / send-image script
###############################################

# Optional override for tests/script/send-e2ee-image.ts.
# Leave FB_E2EE_MEDIA_UPLOAD_AUTH empty to query a fresh media_conn token from the E2EE stream.
FB_E2EE_MEDIA_UPLOAD_AUTH=
FB_E2EE_MEDIA_UPLOAD_HOST=rupload.facebook.com

# Optional overrides for tests/script/send-e2ee-image.ts
TEST_E2EE_IMAGE_JID=100042415119261.0@msgr
TEST_E2EE_IMAGE_PATH=./tests/data/1x1.png
TEST_E2EE_IMAGE_MIME=image/png
TEST_E2EE_IMAGE_CAPTION=
